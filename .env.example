# AutoInsight Environment Variables
# Copy to .env.local with your actual values - DO NOT COMMIT THIS FILE

# Groq AI (get from https://console.groq.com)
VITE_GROQ_API_KEY=your_groq_api_key_here

# Locus Payment (get from https://beta.paywithlocus.com)
VITE_LOCUS_API_KEY=your_locus_api_key_here
VITE_LOCUS_CHECKOUT_PUBLISHABLE_KEY=your_checkout_publishable_key_here
VITE_LOCUS_WALLET_ADDRESS=your_wallet_address_here

# Supabase Edge Functions (optional - uses demo mode if not set)
VITE_USE_REAL_PAYMENT=false